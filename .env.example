# Base de datos PostgreSQL
POSTGRES_DB=socialmind
POSTGRES_USER=socialmind_user
POSTGRES_PASSWORD=cambia_esto_en_produccion
DATABASE_URL=postgresql://socialmind_user:cambia_esto_en_produccion@db:5432/socialmind

# JWT
JWT_SECRET_KEY=cambia_esto_a_una_cadena_larga_y_aleatoria
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# App
APP_ENV=development
CORS_ORIGINS=http://localhost:3000

# IA y servicios externos (opcionales en desarrollo)
# Sin ANTHROPIC_API_KEY, el Chat con Lumi y la Zona de Calma usan una respuesta de reserva
# Sin OPENAI_API_KEY, la Biblioteca no puede procesar PDFs
# Sin RESEND_API_KEY, la recuperación de contraseña por email no funciona
ANTHROPIC_API_KEY=tu_api_key_aqui
OPENAI_API_KEY=tu_api_key_aqui
RESEND_API_KEY=tu_api_key_aqui
FRONTEND_URL=http://localhost:3000
